{
  "name": "@yunhak/nestjs-kit",
  "version": "0.1.0",
  "description": "NestJS 공용 인프라 모음 — 개인 프로젝트용 스타터 키트",
  "license": "MIT",
  "author": "JOOYUNHAK",
  "repository": {
    "type": "git",
    "url": "https://github.com/JOOYUNHAK/nestjs-kit.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "main": "./dist/common/index.js",
  "types": "./dist/common/index.d.ts",
  "exports": {
    "./common": {
      "types": "./dist/common/index.d.ts",
      "require": "./dist/common/index.js",
      "import": "./dist/common/index.mjs"
    },
    "./security": {
      "types": "./dist/security/index.d.ts",
      "require": "./dist/security/index.js",
      "import": "./dist/security/index.mjs"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "require": "./dist/config/index.js",
      "import": "./dist/config/index.mjs"
    },
    "./email": {
      "types": "./dist/email/index.d.ts",
      "require": "./dist/email/index.js",
      "import": "./dist/email/index.mjs"
    },
    "./logging": {
      "types": "./dist/logging/index.d.ts",
      "require": "./dist/logging/index.js",
      "import": "./dist/logging/index.mjs"
    },
    "./orm": {
      "types": "./dist/orm/index.d.ts",
      "require": "./dist/orm/index.js",
      "import": "./dist/orm/index.mjs"
    },
    "./orm/pool": {
      "types": "./dist/orm/pool/index.d.ts",
      "require": "./dist/orm/pool/index.js",
      "import": "./dist/orm/pool/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "canary": "npm run build && node scripts/run-canary.js",
    "version": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "peerDependencies": {
    "@mikro-orm/core": "^6.0.0",
    "@mikro-orm/migrations": "^6.0.0",
    "@mikro-orm/nestjs": "^6.0.0",
    "@mikro-orm/postgresql": "^6.0.0",
    "@mikro-orm/seeder": "^6.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "passport-jwt": "^4.0.0",
    "reflect-metadata": "^0.2.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/throttler": {
      "optional": true
    },
    "@sentry/nestjs": {
      "optional": true
    },
    "@willsoto/nestjs-prometheus": {
      "optional": true
    },
    "resend": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@mikro-orm/core": "^6.6.13",
    "@mikro-orm/migrations": "^6.6.13",
    "@mikro-orm/nestjs": "^6.1.2",
    "@mikro-orm/postgresql": "^6.6.13",
    "@mikro-orm/seeder": "^6.6.13",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/swagger": "^11.4.1",
    "@nestjs/testing": "^11.1.19",
    "@nestjs/throttler": "^6.5.0",
    "@sentry/nestjs": "^10.50.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@willsoto/nestjs-prometheus": "^6.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "jest": "^29.7.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "resend": "^4.8.0",
    "rxjs": "^7.8.2",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "setupFiles": [
      "reflect-metadata"
    ]
  }
}
